# Zara Secure MCP — Configuration
# Copy to .env and fill in your values.

# ─── Core ────────────────────────────────────────────────────────────────────

# Encryption key for placeholder mapping table (min 16 characters, REQUIRED for production)
ZARA_ENCRYPTION_KEY=change-me-to-a-strong-passphrase-at-least-32-chars

# Transport: "http" (standalone server for Postman testing) or "stdio" (OpenCode-managed)
ZARA_MCP_TRANSPORT=http

# Server (HTTP mode only)
ZARA_MCP_PORT=8530
ZARA_MCP_HOST=127.0.0.1
ZARA_LOG_LEVEL=info

# MCP identity
ZARA_MCP_NAME=zara-secure-mcp
ZARA_MCP_VERSION=0.2.0

# Storage (mapping store for reversible placeholders)
ZARA_DB_PATH=~/.zara/privacymcp/mappings.db

# Scanning limits
ZARA_MAX_CONTEXT_BYTES=1048576

# Compression
ZARA_MAX_TOKENS=4096
ZARA_COMPRESS_ENABLED=true

# Metrics
ZARA_METRICS_ENABLED=true
ZARA_METRICS_PORT=8531

# ─── Database Connections ────────────────────────────────────────────────────
# Format: ZARA_DB_<NAME>_DRIVER and ZARA_DB_<NAME>_DSN
# Supported drivers: postgres, mysql, mariadb, sqlserver, sqlite
# Aliases: pg/postgresql (postgres), maria (mysql), mssql/microsoft (sqlserver), sqlite3 (sqlite)
# Auto-detect: if DRIVER is not set or is unknown, it will be detected from the DSN format

# Example: PostgreSQL
# ZARA_DB_PROD_DRIVER=postgres
# ZARA_DB_PROD_DSN=postgres://user:password@localhost:5432/mydb?sslmode=require
# ZARA_DB_PROD_MAX_CONNS=10
# ZARA_DB_PROD_MAX_IDLE_CONNS=5
# ZARA_DB_PROD_CONN_MAX_LIFETIME=1800
# ZARA_DB_PROD_CONN_MAX_IDLE_TIME=300

# Example: MySQL
# ZARA_DB_MYSQL_DRIVER=mysql
# ZARA_DB_MYSQL_DSN=user:password@tcp(localhost:3306)/mydb?charset=utf8mb4&parseTime=true

# Example: MariaDB (uses mysql driver, fully compatible)
# ZARA_DB_MARIADB_DRIVER=mariadb
# ZARA_DB_MARIADB_DSN=user:password@tcp(localhost:3307)/mydb

# Example: SQL Server
# ZARA_DB_MSSQL_DRIVER=sqlserver
# ZARA_DB_MSSQL_DSN=sqlserver://user:password@localhost:1433?database=mydb&encrypt=disable

# Example: SQLite
# ZARA_DB_LOCAL_DRIVER=sqlite
# ZARA_DB_LOCAL_DSN=/tmp/dev.db

# Example: Auto-detect from DSN (no need to set DRIVER)
# ZARA_DB_AUTO_DRIVER=auto
# ZARA_DB_AUTO_DSN=postgres://user:pass@localhost:5432/mydb  # → auto-detected as postgres

# Example: Oracle
# ZARA_DB_ORA_DRIVER=oracle
# ZARA_DB_ORA_DSN=oracle://user:password@localhost:1521/ORCLPDB1

# Example: ClickHouse
# ZARA_DB_CH_DRIVER=clickhouse
# ZARA_DB_CH_DSN=clickhouse://user:password@localhost:9000/default

# ─── MongoDB Connections ─────────────────────────────────────────────────────
# Format: ZARA_MONGO_<NAME>_URI and ZARA_MONGO_<NAME>_DATABASE

# Example: MongoDB
# ZARA_MONGO_PROD_URI=mongodb://user:password@localhost:27017
# ZARA_MONGO_PROD_DATABASE=myapp

# Example: MongoDB Atlas
# ZARA_MONGO_ATLAS_URI=mongodb+srv://user:password@cluster0.example.mongodb.net
# ZARA_MONGO_ATLAS_DATABASE=myapp

# ─── Redis Connections ───────────────────────────────────────────────────────
# Format: ZARA_REDIS_<NAME>_ADDR plus optional username/password/db

# Example: Redis
# ZARA_REDIS_CACHE_ADDR=localhost:6379
# ZARA_REDIS_CACHE_USERNAME=
# ZARA_REDIS_CACHE_PASSWORD=
# ZARA_REDIS_CACHE_DB=0
# ZARA_REDIS_CACHE_POOL_SIZE=10
# ZARA_REDIS_CACHE_MIN_IDLE_CONNS=2
# ZARA_REDIS_CACHE_CONN_MAX_IDLE_TIME=300

# Example: Redis with ACL auth (Redis 6+)
# ZARA_REDIS_SESSION_ADDR=redis.example.com:6380
# ZARA_REDIS_SESSION_USERNAME=myuser
# ZARA_REDIS_SESSION_PASSWORD=secret
# ZARA_REDIS_SESSION_DB=1

# ─── HTTP API Connections ────────────────────────────────────────────────────
# Format: ZARA_API_<NAME>_URL plus optional auth config
# Auth types: none, bearer, basic, header

# Example: GitHub API
# ZARA_API_GITHUB_URL=https://api.github.com
# ZARA_API_GITHUB_AUTH=bearer
# ZARA_API_GITHUB_AUTH_ENV=GITHUB_TOKEN

# Example: Custom API with custom header
# ZARA_API_MYAPI_URL=https://myapi.example.com/v1
# ZARA_API_MYAPI_AUTH=header
# ZARA_API_MYAPI_AUTH_ENV=MYAPI_KEY
# ZARA_API_MYAPI_HEADER_X-API-Key={env:MYAPI_KEY}

# ─── AI Provider Connections ─────────────────────────────────────────────────
# Format: ZARA_AI_<NAME>_BASE_URL, _API_KEY_ENV, _MODELS
# Messages are automatically redacted before sending and unredacted after response.

# Example: OpenAI
# ZARA_AI_OPENAI_BASE_URL=https://api.openai.com
# ZARA_AI_OPENAI_API_KEY_ENV=OPENAI_API_KEY
# ZARA_AI_OPENAI_MODELS=gpt-4o,gpt-4o-mini,o3

# Example: Anthropic
# ZARA_AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
# ZARA_AI_ANTHROPIC_API_KEY_ENV=ANTHROPIC_API_KEY
# ZARA_AI_ANTHROPIC_MODELS=claude-sonnet-4-20250514,claude-3-5-haiku-20241022

# Example: DeepSeek (OpenAI-compatible)
# ZARA_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
# ZARA_AI_DEEPSEEK_API_KEY_ENV=DEEPSEEK_API_KEY
# ZARA_AI_DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# Example: OpenRouter (OpenAI-compatible)
# ZARA_AI_OPENROUTER_BASE_URL=https://openrouter.ai/api
# ZARA_AI_OPENROUTER_API_KEY_ENV=OPENROUTER_API_KEY
# ZARA_AI_OPENROUTER_MODELS=openai/gpt-4o,anthropic/claude-sonnet-4-20250514

# Example: Google Gemini
# ZARA_AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# ZARA_AI_GEMINI_API_KEY_ENV=GEMINI_API_KEY
# ZARA_AI_GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-pro

# Example: Groq (OpenAI-compatible, fast inference)
# ZARA_AI_GROQ_BASE_URL=https://api.groq.com/openai
# ZARA_AI_GROQ_API_KEY_ENV=GROQ_API_KEY
# ZARA_AI_GROQ_MODELS=llama-3.3-70b-versatile,mixtral-8x7b-32768

# Example: Local model (OpenAI-compatible, e.g. Ollama, vLLM, LocalAI)
# ZARA_AI_LOCAL_BASE_URL=http://localhost:11434/v1
# ZARA_AI_LOCAL_API_KEY_ENV=LOCAL_API_KEY
# ZARA_AI_LOCAL_MODELS=llama3.2,qwen2.5

# ─── OpenObserve (Observability) ─────────────────────────────────────────────
# Sends logs/telemetry to OpenObserve for monitoring tool usage and performance.

# ZARA_OBSERVE_ENABLED=false
# ZARA_OBSERVE_URL=http://localhost:5080
# ZARA_OBSERVE_USER=root@example.com
# ZARA_OBSERVE_KEY=your-openobserve-api-key
# ZARA_OBSERVE_STREAM=zara-mcp

# ─── Hot Reload ──────────────────────────────────────────────────────────────
# Send SIGHUP to reload config without restart: kill -HUP $(pgrep zara-secure-mcp)

# ZARA_RELOAD_ENABLED=true
