{
  "info": {
    "name": "Zara Privacy MCP",
    "description": "Test collection for Zara Privacy MCP — context security layer for OpenCode.\n\nServer: POST http://127.0.0.1:8530/mcp\n\nAll requests use JSON-RPC 2.0 protocol.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. initialize",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response has server_name\", () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.result.server_name).to.eql('zara-privacy-mcp');",
              "    pm.expect(json.result.protocol_version).to.eql('2025-03-26');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"initialize\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8530/mcp",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8530",
          "path": ["mcp"]
        }
      }
    },
    {
      "name": "2. list_tools",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Has 7 tools\", () => {",
              "    const tools = pm.response.json().result.tools;",
              "    pm.expect(tools.length).to.eql(7);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 2,\n    \"method\": \"list_tools\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8530/mcp",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8530",
          "path": ["mcp"]
        }
      }
    },
    {
      "name": "3. scan_context (secrets + PII)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 3,\n    \"method\": \"call_tool\",\n    \"params\": {\n        \"name\": \"scan_context\",\n        \"arguments\": {\n            \"text\": \"Hi team, my OpenAI key is sk-proj-ABCDefghijklmnopqrstuvwxyz123456 and my email is aldo@email.com. You can call me at 081234567890.\",\n            \"locales\": [\"id\", \"global\"]\n        }\n    }\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8530/mcp",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8530",
          "path": ["mcp"]
        }
      }
    },
